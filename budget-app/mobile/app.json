{
  "expo": {
    "name": "Tower",
    "slug": "budget-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "description": "Tower connects to your bank accounts and gives you a real-time financial wellness score — so you always know where your money is going and how to spend smarter.",
    "privacy": "https://bartheart.github.io/tower/privacy.html",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.manicmonk.budget",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Tower uses Face ID to keep your financial data secure.",
        "NSCameraUsageDescription": "Tower uses the camera to scan checks and documents when linking your bank account.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "tower"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.78330911812-pgerchhlsf6rk0a45jbqs6b8g3emulsb"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.manicmonk.budget"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "tower",
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-apple-authentication",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "91e461dd-f379-4f2d-9a69-72b76f755076"
      }
    }
  }
}
